ityFromRatio / saha_relation / electronDensity_antitone / SahaInverse.saha_joint_identifiability", "true_ne": 4.000000000, "recovered_ne": 4.000000000, "sahaFactor": 1.909112181, "stage_ratio": 0.477278045, "must": "recover Nz and Nz1 from forward intensities; R = Nz1/Nz; ne = S(T)/R == true ne; and R*ne == S(T) (Saha law)"}}}, {"name": "error-budget thresholds — min energy spread, min SNR, and the temperature / composition budgets DERIVED from the proven error-propagation chain", "kind": "error-budget", "inputs": {"tauBeta": 0.050000000, "snr": 0.020000000, "n": 6.000000000, "ssE": 8.000000000, "kB": 1.000000000, "T": 1.000000000, "relTtarget": 0.030000000, "tauC": 0.010000000, "Shat": 10.000000000, "card": 3.000000000, "vPerLine": 1.500000000}, "thresholds": {"requiredEnergySpread": 0.960000000, "maxPerLineError": 0.057735027, "requiredMinLinesStat": 0.106666667, "slopeTargetFromTempRel": 0.030000000, "densityBudgetFromComposition": 0.025000000, "noiseGain": 0.125000000}, "checks": {"energy_spread_tight": {"theorem": "ErrorBudget.requiredEnergySpread_sufficient", "bound_at_threshold": 0.050000000, "tauBeta": 0.050000000, "must": "slopeErrorBound(snr, n, requiredEnergySpread(tauBeta,snr,n)) == tauBeta (threshold is tight)"}, "snr_tight": {"theorem": "ErrorBudget.maxPerLineError_sufficient", "bound_at_threshold": 0.050000000, "tauBeta": 0.050000000, "must": "slopeErrorBound(maxPerLineError(tauBeta,n,ssE), n, ssE) == tauBeta (threshold is tight)"}, "noise_gain": {"theorem": "ErrorBudget.olsSlope_noise_gain", "noiseGain": 0.125000000, "ssE": 8.000000000, "must": "noiseGain == 1/ssE (Gauss-Markov slope-variance multiplier)"}, "temp_rel": {"theorem": "ErrorBudget.temp_rel_error_eq", "slopeTarget": 0.030000000, "relTtarget": 0.030000000, "must": "slopeTargetFromTempRel(relTtarget,kB,T) * (kB*T) == relTtarget (exact)"}, "composition_budget": {"theorem": "ErrorBudget.composition_target_sufficient", "densityBudget": 0.025000000, "tauC": 0.010000000, "Shat": 10.000000000, "card": 3.000000000, "must": "(card+1)*densityBudgetFromComposition(tauC,Shat,card) == tauC*Shat (budget saturates the target)"}}}, {"name": "energy/wavelength ordinate — one element through the energy forward map with DISTINCT per-line lambda; proves the wavelength (ln(I*lambda/gA)) and photon-rate (ln(I/gA)) conventions agree", "kind": "energy-ordinate", "constants": {"hc": 2.000000000, "fourPi": 4.000000000, "Fgeo": 1.500000000}, "element": {"g": [2.000000000, 4.000000000, 6.000000000, 8.000000000], "E": [0.000000000, 1.200000000, 2.500000000, 3.800000000], "A": [1.000000000, 0.700000000, 0.500000000, 0.300000000], "lambda": [3.000000000, 2.600000000, 2.100000000, 1.700000000], "N": 5.000000000, "intensities": [0.644952739, 0.313798206, 0.113444882, 0.030553604]}, "checks": {"forward": {"theorem": "ForwardMapEnergy.lineIntensityEnergy", "must": "lineIntensityEnergy(hc,4pi,N,Fgeo, g,E,A,lambda, k) == element.intensities[k]"}, "reduction": {"theorem": "ForwardMapEnergy.lineIntensityEnergy_eq_lineIntensity", "must": "lineIntensityEnergy[k] == lineIntensity(Fcal = hc*Fgeo/(4pi*lambda[k]))[k] (per-line Fcal reduction)"}, "mul_lam": {"theorem": "ForwardMapEnergy.lineIntensityEnergy_mul_lam", "must": "lineIntensityEnergy[k] * lambda[k] == lineIntensity(Fcal = hc*Fgeo/(4pi))[k] (lambda cancels the 1/lambda photon-energy factor)"}, "temperature": {"theorem": "ForwardMapEnergy.temperature_from_two_lines_wavelength", "true_T": 1.000000000, "must": "2-line slope of the wavelength ordinate ln(I*lambda/(g*A)) recovers T (distinct per-line lambda; lambda cancels)"}}}]
