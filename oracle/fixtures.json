ityFromRatio / saha_relation / electronDensity_antitone / SahaInverse.saha_joint_identifiability", "true_ne": 4.000000000, "recovered_ne": 4.000000000, "sahaFactor": 1.909112181, "stage_ratio": 0.477278045, "must": "recover Nz and Nz1 from forward intensities; R = Nz1/Nz; ne = S(T)/R == true ne; and R*ne == S(T) (Saha law)"}}}, {"name": "error-budget thresholds — min energy spread, min SNR, and the temperature / composition budgets DERIVED from the proven error-propagation chain", "kind": "error-budget", "inputs": {"tauBeta": 0.050000000, "snr": 0.020000000, "n": 6.000000000, "ssE": 8.000000000, "kB": 1.000000000, "T": 1.000000000, "relTtarget": 0.030000000, "tauC": 0.010000000, "Shat": 10.000000000, "card": 3.000000000, "vPerLine": 1.500000000}, "thresholds": {"requiredEnergySpread": 0.960000000, "maxPerLineError": 0.057735027, "requiredMinLinesStat": 0.106666667, "slopeTargetFromTempRel": 0.030000000, "densityBudgetFromComposition": 0.025000000, "noiseGain": 0.125000000}, "checks": {"energy_spread_tight": {"theorem": "ErrorBudget.requiredEnergySpread_sufficient", "bound_at_threshold": 0.050000000, "tauBeta": 0.050000000, "must": "slopeErrorBound(snr, n, requiredEnergySpread(tauBeta,snr,n)) == tauBeta (threshold is tight)"}, "snr_tight": {"theorem": "ErrorBudget.maxPerLineError_sufficient", "bound_at_threshold": 0.050000000, "tauBeta": 0.050000000, "must": "slopeErrorBound(maxPerLineError(tauBeta,n,ssE), n, ssE) == tauBeta (threshold is tight)"}, "noise_gain": {"theorem": "ErrorBudget.olsSlope_noise_gain", "noiseGain": 0.125000000, "ssE": 8.000000000, "must": "noiseGain == 1/ssE (Gauss-Markov slope-variance multiplier)"}, "temp_rel": {"theorem": "ErrorBudget.temp_rel_error_eq", "slopeTarget": 0.030000000, "relTtarget": 0.030000000, "must": "slopeTargetFromTempRel(relTtarget,kB,T) * (kB*T) == relTtarget (exact)"}, "composition_budget": {"theorem": "ErrorBudget.composition_target_sufficient", "densityBudget": 0.025000000, "tauC": 0.010000000, "Shat": 10.000000000, "card": 3.000000000, "must": "(card+1)*densityBudgetFromComposition(tauC,Shat,card) == tauC*Shat (budget saturates the target)"}}}, {"name": "energy/wavelength ordinate — one element through the energy forward map with DISTINCT per-line lambda; proves the wavelength (ln(I*lambda/gA)) and photon-rate (ln(I/gA)) conventions agree", "kind": "energy-ordinate", "constants": {"hc": 2.000000000, "fourPi": 4.000000000, "Fgeo": 1.500000000}, "element": {"g": [2.000000000, 4.000000000, 6.000000000, 8.000000000], "E": [0.000000000, 1.200000000, 2.500000000, 3.800000000], "A": [1.000000000, 0.700000000, 0.500000000, 0.300000000], "lambda": [3.000000000, 2.600000000, 2.100000000, 1.700000000], "N": 5.000000000, "intensities": [0.644952739, 0.313798206, 0.113444882, 0.030553604]}, "checks": {"forward": {"theorem": "ForwardMapEnergy.lineIntensityEnergy", "must": "lineIntensityEnergy(hc,4pi,N,Fgeo, g,E,A,lambda, k) == element.intensities[k]"}, "reduction": {"theorem": "ForwardMapEnergy.lineIntensityEnergy_eq_lineIntensity", "must": "lineIntensityEnergy[k] == lineIntensity(Fcal = hc*Fgeo/(4pi*lambda[k]))[k] (per-line Fcal reduction)"}, "mul_lam": {"theorem": "ForwardMapEnergy.lineIntensityEnergy_mul_lam", "must": "lineIntensityEnergy[k] * lambda[k] == lineIntensity(Fcal = hc*Fgeo/(4pi))[k] (lambda cancels the 1/lambda photon-energy factor)"}, "temperature": {"theorem": "ForwardMapEnergy.temperature_from_two_lines_wavelength", "true_T": 1.000000000, "must": "2-line slope of the wavelength ordinate ln(I*lambda/(g*A)) recovers T (distinct per-line lambda; lambda cancels)"}}}, {"name": "Stark broadening n_e diagnostic + McWhirter LTE bound -- dimensionless Griem linear width inverse (n_e = nRef*width/(2w)) and the sqrt(T)*dE^3 McWhirter shape", "kind": "stark", "constants": {"w": 0.050000000, "nRef": 1.000000000, "width": 0.300000000, "T": 4.000000000, "dE": 2.000000000}, "checks": {"stark_density": {"theorem": "StarkBroadening.starkDensity_recovers", "ne": 3.000000000, "must": "starkDensity(w,nRef,width) == nRef*width/(2w) == ne (Griem linear n_e diagnostic); pipeline estimate_ne_from_stark(width, REF_T_K, stark_w_ref=2w) == REF_NE*ne/nRef"}, "stark_roundtrip": {"theorem": "StarkBroadening.starkFWHM / starkDensity_recovers", "width_roundtrip": 0.300000000, "must": "starkFWHM(w,nRef, starkDensity(w,nRef,width)) == width (forward/inverse round trip)"}, "mcwhirter": {"theorem": "StarkBroadening.mcWhirterBound", "shape": 16.000000000, "must": "mcWhirterShape(T,dE) == sqrt(T)*dE^3 == shape; full McWhirter LTE bound = 1.6e12 * shape (pipeline MCWHIRTER_CONST)"}}}, {"name": "runtime certificates — the 12 predicates of CflibsFormal/Certificates.lean (the typed bridge, dossier 12 M3), each on its non-vacuity witness plus the reference mirror's rejection tests", "kind": "certificates", "certificates": [{"id": "C1", "name": "energy_spread", "theorem": "designNormalMatrix_det_ne_zero_iff", "predicate": "0 < SSe", "inputs": {"E": [0.000000000, 1.000000000]}, "verdict": true, "value": 0.500000000}, {"id": "C2", "name": "joint_rank", "theorem": "jointDesign_det_pos_iff", "predicate": "0 < SSe*SSs - S_Es^2", "inputs": {"E": [0.000000000, 1.000000000, 2.000000000], "s": [0.000000000, 0.000000000, 1.000000000]}, "verdict": true, "value": 0.333333333}, {"id": "C3", "name": "conditioning", "theorem": "boltzmannConditionNumber_ge_one", "predicate": "0 < SSe", "inputs": {"E": [0.000000000, 1.000000000]}, "verdict": true, "value": 0.500000000}, {"id": "C4", "name": "slope_budget", "theorem": "maxPerLineError_sufficient", "predicate": "eps^2 * n <= tauBeta^2 * SSe", "inputs": {"eps": 1.000000000, "tauBeta": 2.000000000, "SSe": 0.500000000, "n": 2.000000000}, "verdict": true, "value": 0.000000000}, {"id": "C5", "name": "temp_budget", "theorem": "temp_rel_error_le", "predicate": "kB * THat * B <= tauT", "inputs": {"kB": 1.000000000, "THat": 2.000000000, "B": 0.500000000, "tauT": 1.000000000}, "verdict": true, "value": 0.000000000}, {"id": "C6", "name": "comp_budget", "theorem": "composition_target_sufficient", "predicate": "(n+1)*delta <= tauC*Shat", "inputs": {"delta": 1.000000000, "tauC": 2.000000000, "Shat": 2.000000000, "n": 2.000000000}, "verdict": true, "value": 1.000000000}, {"id": "C7", "name": "mcwhirter", "theorem": "mcwhirter_iff_thermalizationLimit", "predicate": "C * sqrt(T) * dE^3 <= ne", "inputs": {"C": 1.000000000, "T": 1.000000000, "dE": 1.000000000, "ne": 2.000000000}, "verdict": true, "value": 1.000000000}, {"id": "C9", "name": "saha_iter", "theorem": "sahaIter_tendsto", "predicate": "b < Ntot & sahaEquilibriumNe(S,Ntot) <= b & sqrt(S)/(2 sqrt(Ntot-b)) < 1 & sqrt(S*Ntot) <= b", "inputs": {"S": 1.000000000, "Ntot": 3.000000000, "b": 2.000000000}, "verdict": true, "value": 0.500000000}, {"id": "C10", "name": "damped_iter", "theorem": "dampedMultiElementIter_tendsto", "predicate": "(all s, S[s] > 0) & (all s, Ntot[s] > 0)", "inputs": {"S": [1.000000000, 1.000000000], "Ntot": [1.000000000, 1.000000000]}, "verdict": true, "value": 0.666666667}, {"id": "C12", "name": "known_tau", "theorem": "lineIntensity_eq_selfAbsorbedIntensity_div", "predicate": "0 <= tau", "inputs": {"tau": 1.000000000}, "verdict": true, "value": 1.000000000}, {"id": "C13", "name": "sa_distinct", "theorem": "cogRatio_injOn", "predicate": "0 < w2 & w2 < w1", "inputs": {"w1": 2.000000000, "w2": 1.000000000}, "verdict": true, "value": 1.000000000}, {"id": "C14", "name": "alias_budget", "theorem": "classicDensity_aliasing_error", "predicate": "0 <= delta & delta < 1", "inputs": {"delta": 0.500000000}, "verdict": true, "value": 1.000000000}, {"id": "C1", "name": "energy_spread (reject: flat energies)", "theorem": "designNormalMatrix_det_ne_zero_iff", "predicate": "0 < SSe", "inputs": {"E": [1.000000000, 1.000000000]}, "verdict": false, "value": 0.000000000}, {"id": "C2", "name": "joint_rank (reject: collinear E,s)", "theorem": "jointDesign_det_pos_iff", "predicate": "0 < SSe*SSs - S_Es^2", "inputs": {"E": [0.000000000, 1.000000000], "s": [0.000000000, 2.000000000]}, "verdict": false, "value": 0.000000000}, {"id": "C10", "name": "damped_iter (reject: nonpositive S)", "theorem": "dampedMultiElementIter_tendsto", "predicate": "(all s, S[s] > 0) & (all s, Ntot[s] > 0)", "inputs": {"S": [0.000000000, 1.000000000], "Ntot": [1.000000000, 1.000000000]}, "verdict": false, "value": 0.000000000}, {"id": "C14", "name": "alias_budget (reject: delta = 1)", "theorem": "classicDensity_aliasing_error", "predicate": "0 <= delta & delta < 1", "inputs": {"delta": 1.000000000}, "verdict": false, "value": 0.000000000}]}]
